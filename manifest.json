{
  "manifest_version": 3,
  "name": "Matchup Pro — Podcast Edition",
  "version": "1.1",
  "description": "CFB & NFL Matchup Finder with predictions and on-air script generation for sports podcasters.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "storage",
    "clipboardWrite",
    "identity"
  ],
  "host_permissions": [
    "https://api.collegefootballdata.com/*",
    "https://site.api.espn.com/*"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["popup.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
