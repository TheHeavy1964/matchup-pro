{
  "manifest_version": 3,
  "name": "Football Matchup Finder",
  "version": "1.0",
  "description": "CFB & NFL Matchup Finder with predictions",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage"
  ],
"options_ui": {
  "page": "options.html",
  "open_in_tab": true

},
 "web_accessible_resources": [
    {
      "resources": ["popup.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
